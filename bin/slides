#!/bin/bash
dir=""
extra_flags=()
save_enabled=false

for arg in "$@"; do
  if [[ "$arg" == "--save" ]]; then
    save_enabled=true
  elif [[ -z "$dir" && -d "$arg" ]]; then
    dir="$arg"
  else
    extra_flags+=("$arg")
  fi
done

if [[ -z "$dir" ]]; then
  dir="$(pwd)"
fi

if $save_enabled; then
  save_dir="$dir/fave"
  mkdir -p "$save_dir"
  extra_flags+=(-j "$save_dir")
fi

nohup feh -Y -q -B black -Z -. -r \
  --action 'shotwell "%f"' \
  --action1 'videos "%f"' \
  --action2 'cd "$(dirname "%f")" && setopt nullglob & setsid mpv --loop-playlist *.{gif,mp4,mkv,avi,mov,webm,flv,m4v} &' \
  --action9 'cd "$(dirname "%f")" && slides -D 5 . &' \
  "${extra_flags[@]}" \
  "$dir" >/dev/null 2>&1 &
