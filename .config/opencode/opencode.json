{
    "$schema": "https://opencode.ai/config.json",
    "autoshare": false,
    "autoupdate": true,
    "lsp": {},
    "plugin": [
        "/home/g/.config/opencode/plugins/graphify.js"
    ],
    "mcp": {
        "osgrep": {
            "type": "local",
            "command": [
                "osgrep",
                "mcp"
            ],
            "enabled": false
        },
        "exa": {
            "enabled": false,
            "type": "remote",
            "url": "https://mcp.exa.ai/mcp",
            "headers": {
                "authorization": "Bearer ${EXA_API_KEY}"
            }
        },
        "deepwiki": {
            "enabled": true,
            "type": "remote",
            "url": "https://mcp.deepwiki.com/mcp"
        },
        "chrome-devtools": {
            "enabled": true,
            "type": "local",
            "command": [
                "pnpm",
                "dlx",
                "chrome-devtools-mcp@latest",
                "--no-usage-statistics"
            ]
        },
        "brave-devtools": {
            "enabled": false,
            "type": "local",
            "command": [
                "pnpm",
                "dlx",
                "brave-devtools-mcp@latest"
            ]
        },
        "trigger": {
            "enabled": false,
            "type": "local",
            "command": [
                "pnpm",
                "dlx",
                "trigger.dev@latest",
                "mcp"
            ]
        },
        "codegraph": {
            "type": "local",
            "command": [
                "codegraph",
                "serve",
                "--mcp"
            ],
            "enabled": true
        }
    }
}
